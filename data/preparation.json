        {"text": "飯店訂房確認單（V Hotel Lavender + 金沙酒店）", "priority": "必備"},
        {"text": "動物園三園門票 QR Code（7/5）", "priority": "必備"},
        {"text": "環球影城門票 + 快速通關 QR Code（7/7）", "priority": "必備"},
        {"text": "S.E.A. Aquarium 門票（7/6）", "priority": "必備"},
        {"text": "Skyline Luge 門票（7/6）", "priority": "必備"},
        {"text": "Wings of Time 門票（7/6，若預約）", "priority": "建議"},
        {"text": "旅遊平安險保單", "priority": "建議"},
        {"text": "護照影本（與正本分開放）", "priority": "建議"}
      ]
    },
    {
      "id": "electronics",
      "title": "電子設備與通訊",
      "icon": "📱",
